<mxCell id="c115" value="&lt;p style=&quot;margin:2px 0 0 0;text-align:center;&quot;&gt;&lt;i&gt;«Singleton»&lt;/i&gt;&lt;br/&gt;&lt;b&gt;DBMS — Supabase PostgreSQL&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 0 4px;&quot;&gt;- engine: Engine&lt;br/&gt;- sessionLocal: SessionFactory&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 2px 4px;&quot;&gt;+ executeQuery(sql: String): ResultSet&lt;br/&gt;+ executeUpdate(sql: String): int&lt;br/&gt;+ connectDB(): Session&lt;/p&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#ffffff;strokeColor=#444444;fontSize=10;" vertex="1" parent="1"><mxGeometry x="4185" y="3237" width="330" height="119" as="geometry"/></mxCell>
