                </mxCell>
                <mxCell id="1705" value="&lt;b&gt;Nota 1 — Client&lt;/b&gt;&lt;br/&gt;Nessuna vista dipende da un'altra vista: lo stato di autenticazione si chiede ad AuthService («Singleton»). Le viste osservano i service tramite TanStack Query (pattern Observer). La Facade verso il server e' ApiService: i service di dominio traducono le operazioni del proprio dominio in chiamate ad ApiService." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF9B1;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1">
                    <mxGeometry x="5240" y="4900" width="340" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="1706" value="&lt;b&gt;Nota 2 — BLL&lt;/b&gt;&lt;br/&gt;Lo stato del Mezzo cambia solo tramite ServizioMobilita (pattern State, transizioni valide esplicite). Il calcolo tariffa varia per tipologia di mezzo con il pattern Strategy (IIN-4: nuove tipologie senza modifiche strutturali)." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF9B1;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1">
                    <mxGeometry x="5240" y="5035" width="340" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="1707" value="&lt;b&gt;Nota 3 — DAL&lt;/b&gt;&lt;br/&gt;I repository sono l'unico livello che conosce le entita' ORM: convertono ORM &amp;#8596; Transfer Object verso la BLL (pattern DAO + Transfer Object). La BLL non importa mai dal Model." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF9B1;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1">
                    <mxGeometry x="5240" y="5170" width="340" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="1708" value="&lt;p style=&quot;margin:2px 0 0 0;text-align:center;&quot;&gt;&lt;i&gt;«interface»&lt;/i&gt;&lt;br/&gt;&lt;b&gt;GoogleMaps&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 0 4px;&quot;&gt;&amp;nbsp;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 2px 4px;&quot;&gt;+ recuperaDatiMappa(pos: Coordinate): DatiMappa&lt;br/&gt;+ verificaZona(pos: Coordinate, idMezzo: String): Zona&lt;/p&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
                    <mxGeometry x="5245" y="6847" width="330" height="103" as="geometry"/>
                </mxCell>
                <mxCell id="1709" value="&lt;p style=&quot;margin:2px 0 0 0;text-align:center;&quot;&gt;&lt;i&gt;«Adapter»&lt;/i&gt;&lt;br/&gt;&lt;b&gt;GoogleMapsAdapter&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 0 4px;&quot;&gt;&amp;nbsp;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 2px 4px;&quot;&gt;+ recuperaDatiMappa(pos: Coordinate): DatiMappa&lt;br/&gt;+ verificaZona(pos: Coordinate, idMezzo: String): Zona&lt;br/&gt;- chiamaApiGoogle(req: Request): Response&lt;/p&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
                    <mxGeometry x="5280" y="6990" width="255" height="103" as="geometry"/>
                </mxCell>
                <mxCell id="1710" value="&lt;p style=&quot;margin:2px 0 0 0;text-align:center;&quot;&gt;&lt;i&gt;«sistema esterno»&lt;/i&gt;&lt;br/&gt;&lt;b&gt;Google Maps&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 0 4px;&quot;&gt;&amp;nbsp;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 2px 4px;&quot;&gt;&amp;nbsp;&lt;/p&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#ffffff;strokeColor=#444444;fontSize=10;" vertex="1" parent="1">
