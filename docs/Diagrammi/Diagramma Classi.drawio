                <mxCell id="2032" value="&lt;p style=&quot;margin:2px 0 0 0;text-align:center;&quot;&gt;&lt;i&gt;«entity»&lt;/i&gt;&lt;br/&gt;&lt;b&gt;MetodoPagamento&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 0 4px;&quot;&gt;- id: String&lt;br/&gt;- tipo: TipoMetodo&lt;br/&gt;- predefinito: boolean&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 2px 4px;&quot;&gt;&amp;nbsp;&lt;/p&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
                    <mxGeometry x="4455" y="8639" width="145" height="93" as="geometry"/>
                </mxCell>
                <mxCell id="2033" value="&lt;p style=&quot;margin:2px 0 0 0;text-align:center;&quot;&gt;&lt;i&gt;«entity»&lt;/i&gt;&lt;br/&gt;&lt;b&gt;Zona&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 0 4px;&quot;&gt;- id: String&lt;br/&gt;- nome: String&lt;br/&gt;- perimetro: Coordinate[]&lt;br/&gt;- tipoZona: TipoZona&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 2px 4px;&quot;&gt;&amp;nbsp;&lt;/p&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
