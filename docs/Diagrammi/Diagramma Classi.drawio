                <mxCell id="Pz1459YSG_InJ0XiHGun-457" value="&lt;p style=&quot;margin:2px 0 0 0;text-align:center;&quot;&gt;&lt;i&gt;«entity»&lt;/i&gt;&lt;br/&gt;&lt;b&gt;Tariffa&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 0 4px;&quot;&gt;- id: String&lt;br/&gt;- tipoMezzo: TipoMezzo&lt;br/&gt;- costoPerMinuto: float&lt;br/&gt;- costoPerKm: float&lt;br/&gt;- aggiornataAt: DateTime&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 2px 4px;&quot;&gt;&amp;nbsp;&lt;/p&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" parent="1" vertex="1">
