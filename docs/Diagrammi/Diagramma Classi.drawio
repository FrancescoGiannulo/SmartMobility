                <mxCell id="854" value="&lt;p style=&quot;margin:2px 0 0 0;text-align:center;&quot;&gt;&lt;i&gt;«entity»&lt;/i&gt;&lt;br/&gt;&lt;b&gt;Tariffa&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 0 4px;&quot;&gt;- id: String&lt;br/&gt;- tipoMezzo: TipoMezzo&lt;br/&gt;- costoPerMinuto: float&lt;br/&gt;- costoPerKm: float&lt;br/&gt;- aggiornataAt: DateTime&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 2px 4px;&quot;&gt;&amp;nbsp;&lt;/p&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
                    <mxGeometry x="3505" y="3692" width="185" height="119" as="geometry"/>
                </mxCell>
                <mxCell id="855" value="&lt;p style=&quot;margin:2px 0 0 0;text-align:center;&quot;&gt;&lt;i&gt;«entity»&lt;/i&gt;&lt;br/&gt;&lt;b&gt;Pagamento&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 0 4px;&quot;&gt;- id: String&lt;br/&gt;- importo: float&lt;br/&gt;- importoPieno: float&lt;br/&gt;- dataOra: DateTime&lt;br/&gt;- stato: StatoPagamento&lt;br/&gt;- offertaApplicataId: String&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 2px 4px;&quot;&gt;&amp;nbsp;&lt;/p&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
                    <mxGeometry x="3505" y="3829" width="195" height="132" as="geometry"/>
                </mxCell>
                <mxCell id="856" value="&lt;p style=&quot;margin:2px 0 0 0;text-align:center;&quot;&gt;&lt;i&gt;«entity»&lt;/i&gt;&lt;br/&gt;&lt;b&gt;MetodoPagamento&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 0 4px;&quot;&gt;- id: String&lt;br/&gt;- tipo: TipoMetodo&lt;br/&gt;- predefinito: boolean&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 2px 4px;&quot;&gt;&amp;nbsp;&lt;/p&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
                    <mxGeometry x="3505" y="3979" width="145" height="93" as="geometry"/>
                </mxCell>
                <mxCell id="857" value="&lt;p style=&quot;margin:2px 0 0 0;text-align:center;&quot;&gt;&lt;i&gt;«entity»&lt;/i&gt;&lt;br/&gt;&lt;b&gt;Zona&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 0 4px;&quot;&gt;- id: String&lt;br/&gt;- nome: String&lt;br/&gt;- perimetro: Coordinate[]&lt;br/&gt;- tipoZona: TipoZona&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 2px 4px;&quot;&gt;&amp;nbsp;&lt;/p&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
                    <mxGeometry x="3875" y="3692" width="155" height="106" as="geometry"/>
                </mxCell>
                <mxCell id="858" value="&lt;b&gt;Nota 1 — Client&lt;/b&gt;&lt;br/&gt;Nessuna vista dipende da un'altra vista: lo stato di autenticazione si chiede ad AuthService («Singleton»). Le viste osservano i service tramite TanStack Query (pattern Observer). La Facade verso il server e' ApiService: i service di dominio traducono le operazioni del proprio dominio in chiamate ad ApiService." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF9B1;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1">
                    <mxGeometry x="4290" y="240" width="340" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="859" value="&lt;b&gt;Nota 2 — BLL&lt;/b&gt;&lt;br/&gt;Lo stato del Mezzo cambia solo tramite ServizioMobilita (pattern State, transizioni valide esplicite). Il calcolo tariffa varia per tipologia di mezzo con il pattern Strategy (IIN-4: nuove tipologie senza modifiche strutturali)." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF9B1;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1">
                    <mxGeometry x="4290" y="375" width="340" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="860" value="&lt;b&gt;Nota 3 — DAL&lt;/b&gt;&lt;br/&gt;I repository sono l'unico livello che conosce le entita' ORM: convertono ORM &amp;#8596; Transfer Object verso la BLL (pattern DAO + Transfer Object). La BLL non importa mai dal Model." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF9B1;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1">
                    <mxGeometry x="4290" y="510" width="340" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="861" value="&lt;p style=&quot;margin:2px 0 0 0;text-align:center;&quot;&gt;&lt;i&gt;«interface»&lt;/i&gt;&lt;br/&gt;&lt;b&gt;GoogleMaps&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 0 4px;&quot;&gt;&amp;nbsp;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 2px 4px;&quot;&gt;+ recuperaDatiMappa(pos: Coordinate): DatiMappa&lt;br/&gt;+ verificaZona(pos: Coordinate, idMezzo: String): Zona&lt;/p&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
                    <mxGeometry x="4295" y="2187" width="330" height="103" as="geometry"/>
                </mxCell>
                <mxCell id="862" value="&lt;p style=&quot;margin:2px 0 0 0;text-align:center;&quot;&gt;&lt;i&gt;«Adapter»&lt;/i&gt;&lt;br/&gt;&lt;b&gt;GoogleMapsAdapter&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 0 4px;&quot;&gt;&amp;nbsp;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0 2px 2px 4px;&quot;&gt;+ recuperaDatiMappa(pos: Coordinate): DatiMappa&lt;br/&gt;+ verificaZona(pos: Coordinate, idMezzo: String): Zona&lt;br/&gt;- chiamaApiGoogle(req: Request): Response&lt;/p&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
                    <mxGeometry x="4330" y="2330" width="255" height="103" as="geometry"/>
                </mxCell>
